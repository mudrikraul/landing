---
import { siteConfig } from "@/config/site";
import { galleryItems } from "@/data/gallery";
import GalleryCard from "@/components/gallery/GalleryCard.astro";
import GalleryControls from "@/components/gallery/GalleryControls.astro";
---

<section class="section gallery section--photo" id="gallery" data-scroll-section>
  <div class="section-bg">
    <img src={siteConfig.galleryBackground} width="1920" height="1100" alt="Gallery background" loading="lazy" decoding="async" />
  </div>
  <div class="section__inner">
    <div class="section-heading">
      <h2 class="section-title">Галерея</h2>
      <p class="section-copy">
        Живые фрагменты процесса, атмосфера работы и визуальные материалы, которые будут открываться в полноэкранной модалке.
      </p>
    </div>
    <div class="gallery__shell">
      <div class="gallery-track" id="galleryTrack">
        {galleryItems.map((item) => <GalleryCard item={item} />)}
      </div>
      <GalleryControls />
    </div>
  </div>
</section>

<style>
  .section {
    position: relative;
    scroll-margin-top: calc(var(--header-height) + 18px);
  }

  .section--photo {
    color: var(--color-white);
  }

  .section-bg,
  .section-bg img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .section-bg {
    overflow: hidden;
  }

  .section-bg img {
    object-fit: cover;
    object-position: center;
    transform: scale(1.03);
  }

  .section-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(8, 8, 8, 0.88) 0%, rgba(8, 8, 8, 0.68) 42%, rgba(8, 8, 8, 0.18) 100%),
      linear-gradient(180deg, rgba(8, 8, 8, 0.2) 0%, rgba(8, 8, 8, 0.48) 100%);
  }

  .gallery {
    min-height: 100svh;
    padding: 0 24px;
    overflow: hidden;
    background: #111116;
  }

  .gallery .section-bg img {
    object-position: center;
    transform: none;
  }

  .gallery .section-bg::after {
    background:
      linear-gradient(180deg, rgba(8, 8, 8, 0.62) 0%, rgba(8, 8, 8, 0.88) 100%),
      linear-gradient(90deg, rgba(8, 8, 8, 0.64) 0%, rgba(8, 8, 8, 0.32) 48%, rgba(8, 8, 8, 0.72) 100%);
  }

  .gallery .section__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    min-height: inherit;
    max-width: 1320px;
    margin-inline: auto;
    padding: 69px 0 160px;
  }

  .gallery .section-heading {
    display: block;
    margin: 0 0 120px 120px;
  }

  .gallery .section-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 400;
    line-height: 62px;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .gallery .section-copy {
    display: none;
  }

  .gallery__shell {
    position: relative;
    width: 100%;
  }

  .gallery-track {
    display: flex;
    gap: 32px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .gallery-track::-webkit-scrollbar {
    display: none;
  }

  @media (max-width: 1024px) {
    .gallery {
      display: none;
    }
  }
</style>
