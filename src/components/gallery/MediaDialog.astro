<dialog class="media-dialog" id="media-dialog" aria-label="Просмотр материала">
  <button class="media-dialog__close" type="button" data-close-media aria-label="Закрыть материал">×</button>
  <div class="media-dialog__body" data-media-body></div>
</dialog>

<style>
  .media-dialog {
    inset: 50% auto auto 50%;
    width: min(1120px, calc(100vw - 40px));
    height: min(760px, calc(100dvh - 40px));
    overflow: visible;
    background: #0b0b0e;
    box-shadow: var(--shadow-dialog);
    transform: translate(-50%, -50%);
  }

  .media-dialog__close {
    position: absolute;
    z-index: 2;
    top: -14px;
    right: -14px;
    display: grid;
    width: 46px;
    height: 46px;
    place-items: center;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-size: 1.8rem;
    cursor: pointer;
  }

  .media-dialog__body,
  .media-dialog__body :global(iframe),
  .media-dialog__body :global(img) {
    width: 100%;
    height: 100%;
  }

  .media-dialog__body :global(iframe) {
    border: 0;
  }

  .media-dialog__body :global(img) {
    object-fit: contain;
  }
</style>

