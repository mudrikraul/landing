---
import type { SocialLink } from "@/types/site";

interface Props {
  links: readonly SocialLink[];
  variant?: "default" | "contact";
}

const { links, variant = "default" } = Astro.props;
---

<div class={`social-links social-links--${variant}`}>
  {links.map((link) => {
    const href = link.href ?? "#";
    const isExternal = href !== "#" && !href.startsWith("#");

    return (
    <a href={href} target={isExternal ? "_blank" : undefined} rel={isExternal ? "noopener noreferrer" : undefined}>
      <span class="social-links__icon" aria-hidden="true">
        {link.icon === "instagram" && (
          <svg viewBox="0 0 24 24" focusable="false">
            <rect x="4" y="4" width="16" height="16" rx="5" fill="none" stroke="currentColor" stroke-width="2"></rect>
            <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2"></circle>
            <circle cx="17.4" cy="6.6" r="1.4" fill="currentColor"></circle>
          </svg>
        )}
        {link.icon === "telegram" && (
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M21.6 4.2 18.4 19.3c-.24 1.08-.88 1.34-1.79.84l-4.94-3.64-2.38 2.3c-.26.26-.48.48-.98.48l.35-5.03 9.16-8.27c.4-.35-.09-.55-.61-.2L5.9 12.95 1.03 11.43c-1.06-.33-1.08-1.06.22-1.57L20.06 3.08c.94-.34 1.76.23 1.54 1.12Z"></path>
          </svg>
        )}
        {link.icon === "youtube" && (
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M21.58 7.18s-.2-1.44-.82-2.08c-.79-.84-1.67-.84-2.07-.89C15.79 4 12 4 12 4s-3.8 0-6.69.21c-.4.05-1.29.05-2.07.89-.62.64-.82 2.08-.82 2.08S2.2 8.88 2.2 10.58v1.59c0 1.7.21 3.4.21 3.4s.2 1.44.82 2.08c.79.84 1.82.81 2.28.9 1.65.16 6.49.21 6.49.21s3.79 0 6.69-.22c.4-.05 1.29-.05 2.07-.89.62-.64.82-2.08.82-2.08s.21-1.7.21-3.4v-1.59c0-1.7-.21-3.4-.21-3.4ZM9.87 14.64V8.73l5.8 2.96-5.8 2.95Z"></path>
          </svg>
        )}
      </span>
      <span>{link.label}</span>
    </a>
    );
  })}
</div>

<style>
  .social-links {
    display: grid;
    gap: 12px;
  }

  .social-links a {
    display: flex;
    align-items: center;
    gap: 12px;
    width: fit-content;
    font-size: 0.82rem;
    color: inherit;
    text-decoration: none;
  }

  .social-links a:hover {
    color: var(--color-accent);
  }

  .social-links__icon {
    display: inline-grid;
    width: 28px;
    height: 28px;
    place-items: center;
    border: 1px solid currentColor;
    border-radius: 50%;
    font-size: 0.65rem;
    text-transform: uppercase;
  }

  .social-links__icon svg {
    display: block;
    width: 62.5%;
    height: 62.5%;
  }

  .social-links--contact {
    gap: 32px;
  }

  .social-links--contact a {
    gap: 16px;
    color: rgba(255, 255, 255, 0.6);
    font-family: var(--font-body);
    font-size: 24px;
    line-height: 24px;
    text-decoration-line: underline;
    text-decoration-color: currentColor;
    text-decoration-thickness: 0.03em;
    text-underline-offset: 0.25em;
    transition: color 220ms ease;
  }

  .social-links--contact a:hover,
  .social-links--contact a:focus-visible {
    color: var(--color-accent);
  }

  .social-links--contact .social-links__icon {
    width: 48px;
    height: 48px;
    border: 0;
    background: rgba(255, 255, 255, 0.6);
    color: #080808;
    transition: background-color 220ms ease, border-color 220ms ease, color 220ms ease;
  }

  .social-links--contact a:hover .social-links__icon,
  .social-links--contact a:focus-visible .social-links__icon {
    background: var(--color-accent);
    color: #080808;
  }

  @media (max-width: 767px) {
    .social-links--contact {
      gap: 0;
      width: 100%;
    }

    .social-links--contact a {
      display: grid;
      grid-template-columns: 32px minmax(0, 1fr);
      gap: 16px;
      align-items: center;
      width: 100%;
      min-height: 54px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
      color: rgba(255, 255, 255, 0.6);
      font-size: 16px;
      line-height: 24px;
    }

    .social-links--contact a:last-child {
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }

    .social-links--contact .social-links__icon {
      width: 32px;
      height: 32px;
      background: rgba(255, 255, 255, 0.68);
      color: #080808;
    }
  }
</style>
