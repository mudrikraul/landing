---
import LeadForm from "./LeadForm.astro";

interface Props {
  headingLevel?: "h1" | "h2";
}

const Heading = Astro.props.headingLevel ?? "h2";
---

<div class="lead-experience__view lead-experience__view--form" data-lead-view="form">
  <div class="lead-experience__card">
    <Heading id="lead-title">Давайте знакомиться</Heading>
    <p class="lead-experience__subtitle">Оставьте ваши данные и мы свяжемся с вами в ближайшее время.</p>
    <LeadForm />
  </div>
</div>

<div class="lead-experience__view lead-experience__view--status" data-lead-view="success" hidden>
  <div class="lead-experience__status lead-experience__status--success">
    <img
      class="lead-experience__status-image"
      src="https://res.cloudinary.com/dohehigsm/image/upload/v1777399326/success_q5fulg.png"
      width="275"
      height="227"
      alt=""
      aria-hidden="true"
      decoding="async"
    />
    <h2>Спасибо! Ваша заявка принята</h2>
    <p>Мы свяжемся с вами в ближайшее время.</p>
  </div>
</div>

<div class="lead-experience__view lead-experience__view--status" data-lead-view="error" hidden>
  <div class="lead-experience__status lead-experience__status--error">
    <span class="lead-experience__status-icon" aria-hidden="true">☹</span>
    <h2>Что-то пошло не так</h2>
    <p data-lead-status-message>Попробуйте перезагрузить страницу.</p>
    <button class="lead-experience__secondary" type="button" data-lead-retry>Вернуться к форме</button>
  </div>
</div>

<style>
  .lead-experience__view {
    display: grid;
    width: 100%;
    place-items: center;
    opacity: 1;
    transform: translateY(0) scale(1);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  .lead-experience__view[hidden] {
    display: none;
  }

  .lead-experience__card {
    width: min(600px, 100%);
    padding: 32px;
    border-radius: 24px;
    background: #ffffff;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
  }

  h1,
  h2 {
    margin: 0;
    font-family: var(--font-body);
    font-size: 32px;
    font-weight: 700;
    line-height: 36px;
    letter-spacing: 0;
  }

  .lead-experience__card h1,
  .lead-experience__card h2 {
    color: #000000;
  }

  .lead-experience__subtitle {
    margin: 8px 0 16px;
    color: #080808;
    font-size: 16px;
    line-height: 18px;
  }

  .lead-experience__view--status {
    color: #ffffff;
    text-align: center;
  }

  .lead-experience__status {
    display: grid;
    width: min(536px, 100%);
    gap: 16px;
    justify-items: center;
  }

  .lead-experience__status h2 {
    color: #ffffff;
  }

  .lead-experience__status p {
    max-width: 536px;
    margin: 0;
    color: rgba(255, 255, 255, 0.56);
    font-size: 16px;
    line-height: 18px;
  }

  .lead-experience__status-image {
    display: block;
    width: min(275px, 100%);
    height: auto;
  }

  .lead-experience__status-icon {
    display: grid;
    width: 120px;
    height: 120px;
    place-items: center;
    border-radius: 50%;
    font-size: 72px;
    line-height: 1;
  }

  .lead-experience__status--error .lead-experience__status-icon {
    background: transparent;
    color: #ffffff;
    font-family: "Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji", var(--font-body);
    font-size: 96px;
  }

  .lead-experience__secondary {
    min-height: 48px;
    padding: 12px 22px;
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 999px;
    background: transparent;
    color: #ffffff;
    cursor: pointer;
    transition: border-color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
  }

  .lead-experience__secondary:hover,
  .lead-experience__secondary:focus-visible {
    border-color: var(--color-accent);
    background: rgba(255, 125, 26, 0.12);
    transform: translateY(-1px);
  }

  @media (max-width: 767px) {
    .lead-experience__card {
      width: min(100%, 600px);
      padding: 24px;
      border-radius: 22px;
    }

    h1,
    h2 {
      font-size: 26px;
      line-height: 31px;
    }

    .lead-experience__subtitle,
    .lead-experience__status p {
      font-size: 14px;
      line-height: 18px;
    }

    .lead-experience__status-icon {
      width: 96px;
      height: 96px;
    }
  }

  @media (max-width: 389px) {
    .lead-experience__card {
      padding: 20px;
    }

    h1,
    h2 {
      font-size: 24px;
      line-height: 29px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lead-experience__view,
    .lead-experience__secondary {
      transition: none;
    }
  }
</style>
