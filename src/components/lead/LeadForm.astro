---
import TurnstileWidget from "./TurnstileWidget.astro";
---

<form class="lead-form" data-lead-form novalidate>
  <div class="lead-form__fields">
    <div class="lead-form__field" data-lead-field>
      <label for="lead-name">Как вас зовут?</label>
      <input id="lead-name" name="name" type="text" autocomplete="name" minlength="2" maxlength="80" placeholder="Как вас зовут?" required />
    </div>

    <div class="lead-form__field" data-lead-field>
      <label for="lead-phone">Ваш номер телефона</label>
      <input id="lead-phone" name="phone" type="tel" autocomplete="tel" inputmode="tel" maxlength="32" placeholder="Ваш номер телефона" required />
    </div>
  </div>

  <div class="lead-form__honeypot" aria-hidden="true">
    <label for="lead-company">Компания</label>
    <input id="lead-company" name="company" type="text" tabindex="-1" autocomplete="off" />
  </div>

  <TurnstileWidget />

  <label class="lead-form__consent">
    <input name="consent" type="checkbox" required />
    <span>Я согласен с <a href="/privacy/" target="_blank" rel="noopener">политикой обработки персональных данных</a>.</span>
  </label>

  <p class="lead-form__error" data-lead-error aria-live="polite"></p>

  <button class="lead-form__submit" type="submit">Отправить</button>
</form>

<style>
  .lead-form {
    display: grid;
    gap: 16px;
  }

  .lead-form__fields {
    display: grid;
    gap: 16px;
  }

  .lead-form__field {
    position: relative;
    display: grid;
    min-height: 48px;
  }

  .lead-form__field label {
    position: absolute;
    top: 8px;
    left: 16px;
    z-index: 1;
    color: #706c6c;
    font-size: 10px;
    line-height: 12px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.16s ease, transform 0.16s ease;
  }

  .lead-form__field.is-filled label,
  .lead-form__field:focus-within label {
    opacity: 1;
    transform: translateY(0);
  }

  input[type="text"],
  input[type="tel"] {
    width: 100%;
    min-height: 48px;
    padding: 14px 16px;
    border: 0;
    border-radius: 12px;
    background: #f6f4f0;
    color: #080808;
    font-size: 16px;
    line-height: 18px;
    outline: 2px solid transparent;
    outline-offset: 0;
    transition: background-color 0.2s ease, outline-color 0.2s ease, box-shadow 0.2s ease;
  }

  .lead-form__field.is-filled input,
  .lead-form__field:focus-within input {
    padding-top: 22px;
    padding-bottom: 6px;
  }

  input[type="text"]:focus,
  input[type="tel"]:focus {
    outline-color: var(--color-accent);
    background: #ffffff;
    box-shadow: 0 0 0 4px rgba(255, 125, 26, 0.12);
  }

  input::placeholder {
    color: #706c6c;
    transition: opacity 0.16s ease;
  }

  .lead-form__field.is-filled input::placeholder,
  .lead-form__field:focus-within input::placeholder {
    opacity: 0;
  }

  .lead-form__honeypot {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .lead-form__consent {
    display: grid;
    grid-template-columns: 18px minmax(0, 1fr);
    gap: 10px;
    align-items: start;
    color: #706c6c;
    font-size: 12px;
    line-height: 16px;
  }

  .lead-form__consent input {
    width: 18px;
    height: 18px;
    margin: 0;
    accent-color: var(--color-accent);
  }

  .lead-form__consent a {
    color: #080808;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .lead-form__error {
    min-height: 16px;
    margin: -6px 0 0;
    color: #b34b1d;
    font-size: 12px;
    line-height: 16px;
  }

  .lead-form__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 72px;
    padding: 24px;
    border: 0;
    border-radius: 12px;
    background: #f6f4f0;
    color: #080808;
    font-size: 16px;
    line-height: 18px;
    cursor: pointer;
    transition: background-color 0.22s ease, color 0.22s ease, transform 0.2s ease, opacity 0.2s ease;
  }

  .lead-form__submit.is-ready {
    background: var(--color-accent);
    color: #ffffff;
  }

  .lead-form__submit.is-ready:hover,
  .lead-form__submit.is-ready:focus-visible {
    background: #ff8a2e;
    transform: translateY(-1px);
  }

  .lead-form__submit:active {
    transform: translateY(0);
  }

  .lead-form__submit:disabled {
    cursor: wait;
    opacity: 0.7;
    transform: none;
  }

  @media (max-width: 767px) {
    .lead-form {
      gap: 14px;
    }

    .lead-form__fields {
      gap: 12px;
    }

    .lead-form__submit {
      min-height: 60px;
      padding: 18px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lead-form__field label,
    input[type="text"],
    input[type="tel"],
    input::placeholder,
    .lead-form__submit {
      transition: none;
    }
  }
</style>
