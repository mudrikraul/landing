---
import LeadExperience from "./LeadExperience.astro";
---

<dialog class="lead-dialog" id="lead-dialog" aria-labelledby="lead-title">
  <button class="lead-dialog__close" type="button" data-close-lead aria-label="Закрыть форму">
    <span aria-hidden="true"></span>
  </button>

  <div class="lead-dialog__stage">
    <LeadExperience headingLevel="h2" />
  </div>
</dialog>

<style>
  .lead-dialog {
    position: fixed;
    inset: 0;
    width: 100vw;
    max-width: none;
    height: 100dvh;
    max-height: none;
    margin: 0;
    padding: 0;
    overflow: hidden;
    border: 0;
    background-color: rgba(34, 33, 38, 0.92);
    color: #080808;
    opacity: 0;
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    filter: drop-shadow(0 12px 40px rgba(0, 0, 0, 0.12));
    transform: scale(0.985);
    transition: opacity 0.28s ease, transform 0.28s ease;
  }

  .lead-dialog::backdrop {
    background: transparent;
  }

  .lead-dialog.is-open {
    opacity: 1;
    transform: scale(1);
  }

  .lead-dialog.is-closing {
    opacity: 0;
    transform: scale(0.985);
  }

  .lead-dialog__stage {
    position: relative;
    display: grid;
    width: 100%;
    height: 100%;
    padding: 96px 32px 72px;
    place-items: center;
    overflow: auto;
  }

  .lead-dialog__close {
    position: absolute;
    top: clamp(28px, 8vw, 100px);
    right: clamp(28px, 8vw, 86px);
    z-index: 3;
    width: 36px;
    height: 36px;
    padding: 0;
    border: 0;
    background: transparent;
    color: #a8a4a4;
    cursor: pointer;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .lead-dialog__close span,
  .lead-dialog__close span::before {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 24px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    content: "";
  }

  .lead-dialog__close span {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .lead-dialog__close span::before {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .lead-dialog__close:hover,
  .lead-dialog__close:focus-visible {
    color: #ffffff;
    transform: scale(1.04);
  }

  @media (max-width: 767px) {
    .lead-dialog__stage {
      padding: 76px 16px 40px;
    }

    .lead-dialog__close {
      top: 24px;
      right: 24px;
    }
  }

  @media (max-width: 389px) {
    .lead-dialog__stage {
      padding-right: 12px;
      padding-left: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lead-dialog,
    .lead-dialog__close {
      transition: none;
    }
  }
</style>
