{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rmflow-landing",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2026-06-22",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  },
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1
    }
  }
}
